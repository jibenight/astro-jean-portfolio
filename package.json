{
  "name": "astro-jean-portfolio",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "dev:cloudflare": "npm run build && wrangler dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "api": "node server.js",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:api": "node --test tests/api.test.js",
    "test:worker": "node --test tests/contact.test.js tests/worker.test.js",
    "test:e2e": "playwright test",
    "check:cloudflare": "wrangler deploy --dry-run",
    "deploy:cloudflare": "npm run validate && wrangler deploy",
    "validate": "npm run check && npm run lint && npm run format:check && npm run test:api && npm run test:worker && npm run build && npm run check:cloudflare"
  },
  "dependencies": {
    "astro": "^7.0.9",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "nodemailer": "^9.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.110.0"
  }
}
