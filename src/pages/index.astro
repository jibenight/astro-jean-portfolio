---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Home from '../components/Home.astro';
import About from '../components/About.astro';
import Portfolio from '../components/Portfolio.astro';
import Skills from '../components/Skills.astro';
import Contact from '../components/Contact.astro';
---

<Layout>
  <!-- Header -->
  <div id="header-wrapper" class="panel active" aria-hidden="false">
    <Header />
  </div>

  <main id="site-content">
    <!-- Home -->
    <div id="home-wrapper" class="panel active" aria-hidden="false">
      <Home />
    </div>

    <!-- Autres sections (hidden) -->
    <div id="about-wrapper" class="panel hidden" aria-hidden="true" inert>
      <About />
    </div>
    <div id="contact-wrapper" class="panel hidden" aria-hidden="true" inert>
      <Contact />
    </div>
    <div id="skills-wrapper" class="panel hidden" aria-hidden="true" inert>
      <Skills />
    </div>
    <div id="portfolio-wrapper" class="panel hidden" aria-hidden="true" inert>
      <Portfolio />
    </div>
  </main>

  <!-- Script principal -->
  <script is:inline>
    const headerEl = document.getElementById('header-wrapper');
    const homeEl = document.getElementById('home-wrapper');
    const sections = {
      about: document.getElementById('about-wrapper'),
      contact: document.getElementById('contact-wrapper'),
      skills: document.getElementById('skills-wrapper'),
      portfolio: document.getElementById('portfolio-wrapper'),
    };
    const sectionTitles = {
      about: 'À propos',
      contact: 'Contact',
      skills: 'Compétences',
      portfolio: 'Portfolio',
    };
    const desktopDirections = {
      about: 'down',
      contact: 'left',
      skills: 'up',
      portfolio: 'right',
    };
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let activeSection = null;

    function setInteractive(el, enabled) {
      if (!el) return;
      el.setAttribute('aria-hidden', String(!enabled));
      if (enabled) el.removeAttribute('inert');
      else el.setAttribute('inert', '');
    }

    function updateVideos(el, shouldPlay) {
      if (!el) return;
      el.querySelectorAll('video').forEach((video) => {
        if (shouldPlay && !reducedMotion.matches) video.play().catch(() => {});
        else video.pause();
      });
    }

    function afterAnimation(el, callback) {
      if (!el || reducedMotion.matches) {
        callback();
        return;
      }
      let completed = false;
      const done = () => {
        if (completed) return;
        completed = true;
        callback();
      };
      el.addEventListener('animationend', done, { once: true });
      window.setTimeout(done, 650);
    }

    function directionFor(sectionId) {
      return window.innerWidth <= 768 ? 'up' : desktopDirections[sectionId];
    }

    function openSection(
      sectionId,
      { updateHistory = true, moveFocus = true } = {},
    ) {
      const section = sections[sectionId];
      if (!section || activeSection === sectionId) return;

      if (activeSection && sections[activeSection]) {
        const previous = sections[activeSection];
        previous.className = 'panel hidden';
        setInteractive(previous, false);
        updateVideos(previous, false);
      }

      activeSection = sectionId;
      const direction = directionFor(sectionId);
      slideIn(section, direction);
      slideOut(headerEl, direction);
      slideOut(homeEl, direction);
      updateVideos(section, true);
      document.title = `${sectionTitles[sectionId]} — Jean Nguyen`;

      document.querySelectorAll('[data-target]').forEach((item) => {
        if (item.getAttribute('data-target') === sectionId) {
          item.setAttribute('aria-current', 'page');
        } else {
          item.removeAttribute('aria-current');
        }
      });

      if (updateHistory) {
        history.pushState({ section: sectionId }, '', `#${sectionId}`);
      }

      if (moveFocus) {
        afterAnimation(section, () => {
          const heading = section.querySelector('h2');
          if (heading) {
            heading.setAttribute('tabindex', '-1');
            heading.focus({ preventScroll: true });
          }
        });
      }
    }

    window.closeSection = function (sectionId, { updateHistory = true } = {}) {
      if (!sections[sectionId]) return;
      const isMobile = window.innerWidth <= 768;
      const opposite = { down: 'up', up: 'down', left: 'right', right: 'left' };
      const direction = isMobile
        ? 'down'
        : opposite[desktopDirections[sectionId]];
      slideOut(sections[sectionId], direction);
      slideIn(headerEl, direction);
      slideIn(homeEl, direction);
      updateVideos(sections[sectionId], false);
      updateVideos(homeEl, true);
      activeSection = null;
      document.title = 'Jean Nguyen — Développeur front-end Astro';
      document
        .querySelectorAll('[data-target]')
        .forEach((item) => item.removeAttribute('aria-current'));
      if (updateHistory) {
        history.pushState({}, '', `${location.pathname}${location.search}`);
      }
      afterAnimation(homeEl, () =>
        document.querySelector('.nav-item')?.focus(),
      );
    };

    function slideIn(el, direction) {
      if (!el) return;
      el.classList.remove('hidden');
      setInteractive(el, true);
      void el.offsetWidth;
      const animClass = {
        down: 'slide-in-down',
        up: 'slide-in-up',
        left: 'slide-in-left',
        right: 'slide-in-right',
      }[direction];
      el.classList.add(animClass);
      afterAnimation(el, () => {
        el.classList.remove(animClass);
        el.classList.add('active');
      });
    }

    function slideOut(el, direction) {
      if (!el) return;
      el.classList.remove('active');

      const animClass = {
        down: 'slide-out-down',
        up: 'slide-out-up',
        left: 'slide-out-left',
        right: 'slide-out-right',
      }[direction];
      el.classList.add(animClass);
      afterAnimation(el, () => {
        el.classList.remove(animClass);
        el.classList.add('hidden');
        setInteractive(el, false);
      });
    }

    function syncFromLocation({ moveFocus = false } = {}) {
      const sectionId = location.hash.slice(1);
      if (sections[sectionId]) {
        openSection(sectionId, { updateHistory: false, moveFocus });
      } else if (activeSection) {
        window.closeSection(activeSection, { updateHistory: false });
      }
    }

    document.querySelectorAll('[data-target]').forEach((item) => {
      item.addEventListener('click', (event) => {
        event.preventDefault();
        const targetId = item.getAttribute('data-target');
        if (targetId) openSection(targetId);
      });
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && activeSection)
        window.closeSection(activeSection);
    });
    window.addEventListener('popstate', () =>
      syncFromLocation({ moveFocus: true }),
    );
    reducedMotion.addEventListener('change', () => {
      updateVideos(homeEl, !activeSection);
      Object.entries(sections).forEach(([id, section]) =>
        updateVideos(section, id === activeSection),
      );
    });
    syncFromLocation();
    updateVideos(homeEl, true);
  </script>
</Layout>

<style is:global>
  #header-wrapper {
    z-index: 50;
    pointer-events: none;
  }

  #header-wrapper .nav-item,
  #header-wrapper .menu-toggle,
  #header-wrapper .mobile-link,
  #header-wrapper .mobile-menu.open {
    pointer-events: auto;
  }
</style>
