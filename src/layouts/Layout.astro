---
import CallPopup from '../components/CallPopup.astro';
import socialImage from '../assets/images/background-jean-Q100.jpg';

const {
  title = 'Jean Nguyen — Développeur front-end Astro',
  description = 'Développeur front-end spécialisé en Astro, performance web, accessibilité et intégration de sites maintenables.',
  noindex = false,
} = Astro.props;

const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site || Astro.url.origin,
);
const socialImageUrl = new URL(socialImage.src, Astro.site || Astro.url.origin);
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Jean Nguyen',
  url: new URL('/', Astro.site || Astro.url.origin).toString(),
  image: socialImageUrl.toString(),
  jobTitle: 'Développeur front-end',
  knowsAbout: ['Astro', 'JavaScript', 'Accessibilité web', 'Performance web'],
  sameAs: ['https://github.com/jibenight'],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/coding-2.png" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta
      name="robots"
      content={noindex ? 'noindex, nofollow' : 'index, follow'}
    />
    <meta name="theme-color" content="#0d8ae8" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#site-content">Aller au contenu</a>
    <slot />
    <CallPopup id="call-popup" />
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        document
          .querySelectorAll('[data-email-user][data-email-domain]')
          .forEach((el) => {
            const user = el.getAttribute('data-email-user') || '';
            const domain = el.getAttribute('data-email-domain') || '';
            if (!user || !domain) return;
            const email = `${user}@${domain}`;
            if (el.tagName === 'A') {
              el.setAttribute('href', `mailto:${email}`);
            }
            if (!el.dataset.noTextReplace) {
              el.textContent = email;
            }
          });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    --primary-color: #1da5fe;
    --primary-dark: #075f9f;
    --text-color: #000;
    --surface: #fff;
    --surface-muted: #f4f7fb;
    --radius-card: 24px;
    --shadow-card: 0 20px 45px rgba(15, 23, 42, 0.1);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    font-family:
      ui-rounded,
      'Nunito',
      system-ui,
      -apple-system,
      sans-serif;
    color: var(--text-color);
  }

  body {
    margin: 0;
  }

  p {
    font-size: 1.1rem;
    line-height: 1.4;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  :where(a, button, input, select, textarea):focus-visible {
    outline: 3px solid #075f9f;
    outline-offset: 3px;
  }

  button.popup-trigger {
    font-size: 1.1rem;
    font-weight: 800;
    border-radius: 26px;
    padding: 1.2rem 2.1rem;
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.14);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 2000;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    background: #fff;
    color: #075f9f;
    font-weight: 700;
    transform: translateY(-160%);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  button.popup-trigger:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 40px rgba(0, 0, 0, 0.16);
  }

  .sub-title {
    margin: 3rem 0;
  }

  .sub-title h2 {
    margin-bottom: 0.5rem;
    text-align: left;
  }

  .sub-title hr {
    width: 100%;
    height: 2px;
    background-color: #202020;
    border: none;
    margin-bottom: 2rem;
  }
  /* entete génerique */
  .container-title {
    width: 100%;
    margin: 0 auto;
    text-align: center;
    padding: 1rem 0;
  }
  .title {
    display: inline-block;
    position: relative;
    margin: 5% 0;
  }

  .title h2 {
    font-size: 2rem;
    margin: 0px;
    text-transform: uppercase;
    position: relative;
    width: auto;
    font-weight: 500;
    padding-bottom: 15px;
  }

  .title h2::after {
    content: '';
    position: absolute;
    background-color: #202020;
    width: 100%;
    height: 2px;
    top: 100%;
    left: 0;
  }

  .title p {
    text-align: right;
    width: auto;
    text-transform: uppercase;
    background-color: #f8f8f8;
    margin: 0px;
    padding-left: 10px;
    position: absolute;
    right: 0;
    bottom: -10px;
    color: #1da5fe;
    font-weight: 500;
  }

  /* button */

  button {
    border: none;
    background: none;
    cursor: pointer;
  }

  body.no-scroll {
    overflow: hidden;
  }

  /* Panel de base (occupant tout l'écran) */
  .panel {
    position: absolute;
    inset: 0; /* top:0; left:0; bottom:0; right:0; */
    overflow: hidden;
  }

  /* Par défaut, .hidden => invisible (display: none) */
  .panel.hidden {
    display: none;
  }

  /* .active => visible sans animation en cours */
  .panel.active {
    display: block;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* ================= ANIMATIONS ===================== */
  /* HAUT → BAS */
  .slide-in-down {
    animation: slideInDown 0.5s forwards ease-in-out;
  }
  @keyframes slideInDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .slide-out-down {
    animation: slideOutDown 0.5s forwards ease-in-out;
  }
  @keyframes slideOutDown {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(100%);
      opacity: 0;
    }
  }

  /* BAS → HAUT */
  .slide-in-up {
    animation: slideInUp 0.5s forwards ease-in-out;
  }
  @keyframes slideInUp {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .slide-out-up {
    animation: slideOutUp 0.5s forwards ease-in-out;
  }
  @keyframes slideOutUp {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(-100%);
      opacity: 0;
    }
  }

  /* GAUCHE → DROITE */
  .slide-in-right {
    animation: slideInRight 0.5s forwards ease-in-out;
  }
  @keyframes slideInRight {
    from {
      transform: translateX(-100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .slide-out-right {
    animation: slideOutRight 0.5s forwards ease-in-out;
  }
  @keyframes slideOutRight {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(100%);
      opacity: 0;
    }
  }

  /* DROITE → GAUCHE */
  .slide-in-left {
    animation: slideInLeft 0.5s forwards ease-in-out;
  }
  @keyframes slideInLeft {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .slide-out-left {
    animation: slideOutLeft 0.5s forwards ease-in-out;
  }
  @keyframes slideOutLeft {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(-100%);
      opacity: 0;
    }
  }
</style>
