---
import { ClientRouter } from 'astro:transitions';
import CallPopup from "../components/CallPopup.astro";
---

<!doctype html>
<html lang='fr'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/png' href='/coding-2.png' />
    <meta name='generator' content={Astro.generator} />
    <meta
      name='description'
      content="Jean Nguyen — développeur front-end Astro/Tailwind : sites ultra-rapides, perfs Core Web Vitals, IA pour livrer plus vite, navigation immersive et prise de contact express."
    />
    <title>Jean Nguyen</title>
    <link rel='preload' as='font' type='font/woff2' href='/fonts/comfortaa/comfortaa-variable-latin.woff2' crossorigin />
    <link rel='stylesheet' href='/fonts/comfortaa/comfortaa.css' />
    <ClientRouter />
  </head>
  <body>
    <slot />
    <CallPopup id="call-popup" />
    <script>
      // Capture la direction au clic sur tout lien marqué data-direction
      // afin que le CSS view-transition applique la bonne animation directionnelle
      // Sur mobile, on utilise data-mobile-direction (toutes les ouvertures = 'up', tous les retours = 'down')
      document.addEventListener('click', (e) => {
        const target = e.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('a[data-direction]');
        if (link instanceof HTMLAnchorElement) {
          const isMobile = window.innerWidth <= 768;
          const direction = isMobile
            ? link.dataset.mobileDirection || link.dataset.direction || ''
            : link.dataset.direction || '';
          document.documentElement.dataset.direction = direction;
        }
      });

      // Reconstruction des emails obfusqués — re-exécuté à chaque page-load
      // (chargement initial + navigation View Transitions)
      const reconstructEmails = () => {
        document
          .querySelectorAll('[data-email-user][data-email-domain]')
          .forEach((el) => {
            const user = el.getAttribute('data-email-user') || '';
            const domain = el.getAttribute('data-email-domain') || '';
            if (!user || !domain) return;
            const email = `${user}@${domain}`;
            if (el.tagName === 'A') {
              el.setAttribute('href', `mailto:${email}`);
            }
            if (!(el instanceof HTMLElement) || !el.dataset.noTextReplace) {
              el.textContent = email;
            }
          });
      };
      document.addEventListener('astro:page-load', reconstructEmails);
    </script>
  </body>
</html>

<style is:global>
  :root {
    /* Ajustez si nécessaire */
    --primary-color: #1da5fe;
    --text-color: #000;
  }

  html {
    font-family: 'Comfortaa', sans-serif;
    font-size: 93.75%; /* 15px base au lieu de 16px — compense la largeur de Comfortaa */
  }

  p {
    font-size: 1.1rem;
    line-height: 1.4;
  }

  a {
    text-decoration: none;
    color: inherit;
    outline: none;
  }

  button.popup-trigger {
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 26px;
    padding: 1.2rem 2.1rem;
    box-shadow: 0 20px 38px rgba(0, 0, 0, 0.14);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  button.popup-trigger:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 40px rgba(0, 0, 0, 0.16);
  }

  .sub-title {
    margin: 3rem 0;
  }

  .sub-title h2 {
    margin-bottom: 0.5rem;
    text-align: left;
  }

  .sub-title hr {
    width: 100%;
    height: 2px;
    background-color: #202020;
    border: none;
    margin-bottom: 2rem;
  }
  /* entete génerique — aligné verticalement avec le bouton Close (top: 20px, h: 56px → centre à 48px) */
  .container-title {
    width: 100%;
    margin: 0 auto;
    text-align: center;
    padding: 0;
  }
  .title {
    display: inline-block;
    position: relative;
    margin: 0 0 2rem;
  }

  .title h2 {
    font-size: 2rem;
    margin: 0px;
    text-transform: uppercase;
    position: relative;
    width: auto;
    font-weight: 500;
    padding-bottom: 15px;
  }

  .title h2::after {
    content: '';
    position: absolute;
    background-color: #202020;
    width: 100%;
    height: 2px;
    top: 100%;
    left: 0;
  }

  .title p {
    text-align: right;
    width: auto;
    text-transform: uppercase;
    background-color: #f8f8f8;
    margin: 0px;
    padding-left: 10px;
    position: absolute;
    right: 0;
    bottom: -10px;
    color: #1da5fe;
    font-weight: 500;
  }

  /* button */

  button {
    border: none;
    background: none;
    cursor: pointer;
  }

  /* Panel de base (occupant tout l'écran) */
  .panel {
    position: absolute;
    inset: 0; /* top:0; left:0; bottom:0; right:0; */
    overflow: hidden;
  }

  /* Par défaut, .hidden => invisible (display: none) */
  .panel.hidden {
    display: none;
  }

  /* .active => visible sans animation en cours */
  .panel.active {
    display: block;
    z-index: 1;
  }

  /* ================= ANIMATIONS ===================== */
  /* HAUT → BAS */
  .slide-in-down {
    animation: slideInDown 0.5s forwards ease-in-out;
  }
  @keyframes slideInDown {
    from {
      transform: translateY(-100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .slide-out-down {
    animation: slideOutDown 0.5s forwards ease-in-out;
  }
  @keyframes slideOutDown {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(100%);
      opacity: 0;
    }
  }

  /* BAS → HAUT */
  .slide-in-up {
    animation: slideInUp 0.5s forwards ease-in-out;
  }
  @keyframes slideInUp {
    from {
      transform: translateY(100%);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  .slide-out-up {
    animation: slideOutUp 0.5s forwards ease-in-out;
  }
  @keyframes slideOutUp {
    from {
      transform: translateY(0);
      opacity: 1;
    }
    to {
      transform: translateY(-100%);
      opacity: 0;
    }
  }

  /* GAUCHE → DROITE */
  .slide-in-right {
    animation: slideInRight 0.5s forwards ease-in-out;
  }
  @keyframes slideInRight {
    from {
      transform: translateX(-100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .slide-out-right {
    animation: slideOutRight 0.5s forwards ease-in-out;
  }
  @keyframes slideOutRight {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(100%);
      opacity: 0;
    }
  }

  /* DROITE → GAUCHE */
  .slide-in-left {
    animation: slideInLeft 0.5s forwards ease-in-out;
  }
  @keyframes slideInLeft {
    from {
      transform: translateX(100%);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }

  .slide-out-left {
    animation: slideOutLeft 0.5s forwards ease-in-out;
  }
  @keyframes slideOutLeft {
    from {
      transform: translateX(0);
      opacity: 1;
    }
    to {
      transform: translateX(-100%);
      opacity: 0;
    }
  }

  /* ============ VIEW TRANSITIONS directionnelles (Astro ClientRouter) ============ */
  /* La direction est posée sur <html data-direction="..."> par le script global
     en fonction du data-direction du lien cliqué. */
  html[data-direction='down'] ::view-transition-old(root) {
    animation: 0.5s ease-in-out forwards slideOutDown;
  }
  html[data-direction='down'] ::view-transition-new(root) {
    animation: 0.5s ease-in-out forwards slideInDown;
  }

  html[data-direction='up'] ::view-transition-old(root) {
    animation: 0.5s ease-in-out forwards slideOutUp;
  }
  html[data-direction='up'] ::view-transition-new(root) {
    animation: 0.5s ease-in-out forwards slideInUp;
  }

  html[data-direction='left'] ::view-transition-old(root) {
    animation: 0.5s ease-in-out forwards slideOutLeft;
  }
  html[data-direction='left'] ::view-transition-new(root) {
    animation: 0.5s ease-in-out forwards slideInLeft;
  }

  html[data-direction='right'] ::view-transition-old(root) {
    animation: 0.5s ease-in-out forwards slideOutRight;
  }
  html[data-direction='right'] ::view-transition-new(root) {
    animation: 0.5s ease-in-out forwards slideInRight;
  }

  /* Respecte la préférence utilisateur "moins d'animations" */
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation: none !important;
    }
  }
</style>
