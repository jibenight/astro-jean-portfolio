---
import Button from './ui/Button.astro';

export interface Props {
  id?: string;
  phone?: string;
  email?: string;
}

const {
  id = 'call-popup',
  phone = '+33 6 11 45 18 56',
  email = 'contact@jean-nguyen.dev',
} = Astro.props;

const phoneHref = `tel:${phone.replace(/\\s+/g, '')}`;
const [emailUser = '', emailDomain = ''] = email.split('@');
---

<div class="popup-overlay" id={id} hidden>
  <div
    class="popup-card"
    role="dialog"
    aria-modal="true"
    aria-labelledby={`${id}-title`}
    aria-describedby={`${id}-description`}
  >
    <button
      class="popup-close"
      type="button"
      data-close-popup={id}
      aria-label="Fermer le pop-up"
    >
      ×
    </button>
    <p class="eyebrow">Contact rapide</p>
    <h3 id={`${id}-title`}>Choisissez votre canal</h3>
    <p class="lead" id={`${id}-description`}>
      Vous pouvez m’appeler directement ou m’écrire un mail. Réponse sous 48h
      maximum.
    </p>
    <div class="popup-actions">
      <Button href={phoneHref}>Appeler</Button>
      <Button
        href="#"
        variant="secondary"
        data-email-user={emailUser}
        data-email-domain={emailDomain}>Écrire un mail</Button
      >
    </div>
  </div>
</div>

<script is:inline data-popup-id={id}>
  (() => {
    const popupId = document.currentScript?.dataset.popupId || 'call-popup';
    const overlay = document.getElementById(popupId);
    if (!overlay) return;
    const dialog = overlay.querySelector('[role="dialog"]');
    const closeButton = overlay.querySelector('[data-close-popup]');
    let opener = null;

    const focusableSelector =
      'a[href], button:not([disabled]), input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';

    const open = (source) => {
      opener = source instanceof HTMLElement ? source : document.activeElement;
      overlay.hidden = false;
      overlay.classList.add('visible');
      document.body.classList.add('no-scroll');
      requestAnimationFrame(() => closeButton?.focus());
    };

    const close = () => {
      overlay.classList.remove('visible');
      overlay.hidden = true;
      document.body.classList.remove('no-scroll');
      if (opener instanceof HTMLElement) opener.focus();
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const opener = target.closest(`[data-open-popup="${popupId}"]`);
      if (opener) {
        event.preventDefault();
        open(opener);
        return;
      }

      const closer = target.closest(`[data-close-popup="${popupId}"]`);
      if (closer) {
        event.preventDefault();
        close();
      }
    });

    overlay.addEventListener('click', (event) => {
      if (event.target === overlay) close();
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && overlay.classList.contains('visible')) {
        close();
      }

      if (event.key === 'Tab' && overlay.classList.contains('visible')) {
        const focusable = [...dialog.querySelectorAll(focusableSelector)];
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      }
    });
  })();
</script>

<style>
  .popup-overlay {
    position: fixed;
    inset: 0;
    background: rgba(7, 17, 31, 0.58);
    display: grid;
    place-items: center;
    z-index: 999;
  }

  .popup-overlay[hidden] {
    display: none;
  }

  .popup-card {
    position: relative;
    background: var(--color-surface);
    padding: 1.8rem;
    border-radius: var(--radius-xl);
    max-width: 480px;
    width: min(90vw, 480px);
    box-shadow: var(--shadow-lg);
    display: grid;
    gap: 0.8rem;
  }

  .popup-close {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: none;
    border: none;
    font-size: 1.4rem;
    cursor: pointer;
    color: var(--color-text-muted);
  }

  .popup-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18rem;
    font-size: 0.8rem;
    margin: 0;
    color: var(--color-text-subtle);
  }

  h3 {
    margin: 0;
  }

  .lead {
    margin: 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .popup-card {
      width: 88vw;
      max-width: 360px;
      padding: 1.25rem;
      gap: 0.7rem;
    }

    .popup-actions {
      flex-direction: column;
      gap: 0.6rem;
    }

    .popup-actions :global(.ui-button) {
      justify-content: center;
      padding: 0.7rem 1rem;
      border-radius: 14px;
    }
  }
</style>
