---
import { Image } from 'astro:assets';
import Close from './Close.astro';
import { getPortfolioProjects } from '../lib/portfolio.js';

const yearsExperience = Math.max(0, new Date().getFullYear() - 2017);
const projects = await getPortfolioProjects();
const selectedFeatured = projects.filter((project) => project.featured);
const featuredProjects = [
  ...selectedFeatured,
  ...projects.filter((project) => !project.featured),
].slice(0, 2);
const featuredIds = new Set(featuredProjects.map((project) => project.id));
const archiveProjects = projects.filter(
  (project) => !featuredIds.has(project.id),
);
const categories = [
  'Tous',
  ...new Set(projects.map((project) => project.category)),
];

const techLabels: Record<string, string> = {
  astro: 'Astro',
  css3: 'CSS',
  express: 'Express',
  ghost: 'Ghost',
  handlebars: 'Handlebars',
  html5: 'HTML',
  js: 'JavaScript',
  nodejs: 'Node.js',
  python: 'Python',
  react: 'React',
  wordpress: 'WordPress',
};

const getTechLabel = (tech: string) => techLabels[tech] || tech;
const getProjectNumber = (index: number) => String(index + 1).padStart(2, '0');
const getProjectYear = (project: { date: string }) =>
  String(project.date).slice(0, 4);
---

<section id="portfolio" class="portfolio-section">
  <Close
    onClick="window.closeSection ? window.closeSection('portfolio') : console.warn('closeSection missing')"
  />

  <div class="portfolio-shell">
    <header class="portfolio-intro">
      <p class="intro-kicker">Portfolio / 01</p>
      <div class="intro-grid">
        <h2>Des sites utiles,<br /><span>rapides</span> et mémorables.</h2>
        <div class="intro-copy">
          <p>
            Je conçois des expériences web légères et maintenables, de la
            stratégie à la mise en ligne. Chaque projet cherche le juste
            équilibre entre identité, performance et simplicité d’usage.
          </p>
          <a href="#selected-work" class="intro-link">
            Découvrir les projets <span aria-hidden="true">↓</span>
          </a>
        </div>
      </div>

      <dl class="portfolio-metrics" aria-label="Chiffres clés du portfolio">
        <div>
          <dt>{projects.length}</dt>
          <dd>projets sélectionnés</dd>
        </div>
        <div>
          <dt>{yearsExperience}+</dt>
          <dd>années d’expérience</dd>
        </div>
        <div>
          <dt>3</dt>
          <dd>écosystèmes maîtrisés</dd>
        </div>
      </dl>
    </header>

    <nav class="filter-bar" aria-label="Filtrer les projets">
      <span class="filter-label">Explorer</span>
      <div class="filter-chips">
        {
          categories.map((category, index) => (
            <button
              type="button"
              class={`chip ${index === 0 ? 'active' : ''}`}
              data-filter={category}
              aria-pressed={index === 0}
            >
              {category}
            </button>
          ))
        }
      </div>
      <p class="filter-status" aria-live="polite">
        {projects.length} projets affichés
      </p>
    </nav>

    <section
      id="selected-work"
      class="portfolio-group selected-work"
      aria-labelledby="selected-work-title"
    >
      <header class="group-heading">
        <div>
          <p class="group-kicker">Sélection</p>
          <h3 id="selected-work-title">Projets à la une</h3>
        </div>
        <span>{String(featuredProjects.length).padStart(2, '0')} études</span>
      </header>

      <div class="featured-list">
        {
          featuredProjects.map((project, index) => (
            <article
              class={`featured-project ${index % 2 === 1 ? 'is-reversed' : ''}`}
              data-project-card
              data-category={project.category}
            >
              <div class="featured-visual">
                {project.imageAsset ? (
                  <Image
                    src={project.imageAsset}
                    alt={project.alt || ''}
                    width={1200}
                    height={760}
                    format="webp"
                    quality={90}
                    loading="lazy"
                    decoding="async"
                    sizes="(max-width: 768px) 100vw, 62vw"
                  />
                ) : (
                  <div class="media-fallback" aria-hidden="true" />
                )}
                <span class="visual-number" aria-hidden="true">
                  {getProjectNumber(index)}
                </span>
              </div>

              <div class="featured-copy">
                <div class="project-overline">
                  <span>{project.category}</span>
                  <span>{getProjectYear(project)}</span>
                </div>
                <h4>{project.title}</h4>
                <p class="project-description">
                  {project.summary || project.creation}
                </p>

                <p class="project-highlight">
                  <span>Impact</span>
                  {project.results[0] ||
                    (project.status === 'online'
                      ? 'Projet actuellement en ligne'
                      : 'Projet archivé')}
                </p>

                <dl class="project-meta">
                  <div>
                    <dt>Rôle</dt>
                    <dd>{project.role || project.creation}</dd>
                  </div>
                  <div>
                    <dt>Technologies</dt>
                    <dd>{project.logos.map(getTechLabel).join(' · ')}</dd>
                  </div>
                </dl>

                <div class="project-actions">
                  <a href={`/projets/${project.id}/`} class="case-link">
                    Voir l’étude de cas <span aria-hidden="true">→</span>
                  </a>
                  <div class="external-links">
                    <a
                      href={project.href}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Site <span aria-hidden="true">↗</span>
                    </a>
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        GitHub <span aria-hidden="true">↗</span>
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section
      class="portfolio-group archive-work"
      aria-labelledby="archive-work-title"
    >
      <header class="group-heading">
        <div>
          <p class="group-kicker">Index</p>
          <h3 id="archive-work-title">Tous les projets</h3>
        </div>
        <span>{String(archiveProjects.length).padStart(2, '0')} projets</span>
      </header>

      <div class="archive-layout">
        <div class="archive-list">
          {
            archiveProjects.map((project, index) => (
              <article
                class="archive-item"
                data-project-card
                data-category={project.category}
              >
                <a
                  href={`/projets/${project.id}/`}
                  class="archive-link"
                  data-preview-target={project.id}
                >
                  <span class="archive-number">
                    {getProjectNumber(featuredProjects.length + index)}
                  </span>
                  <span class="archive-mobile-visual">
                    {project.imageAsset ? (
                      <Image
                        src={project.imageAsset}
                        alt=""
                        width={720}
                        height={480}
                        format="webp"
                        quality={78}
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <span class="media-fallback" aria-hidden="true" />
                    )}
                  </span>
                  <span class="archive-name">
                    <strong>{project.title}</strong>
                    <small>{project.creation}</small>
                  </span>
                  <span class="archive-category">{project.category}</span>
                  <span class="archive-year">{getProjectYear(project)}</span>
                  <span class="archive-arrow" aria-hidden="true">
                    ↗
                  </span>
                </a>
              </article>
            ))
          }
        </div>

        <aside class="archive-preview" aria-hidden="true">
          {
            archiveProjects.map((project, index) => (
              <div
                class={`archive-preview-item ${index === 0 ? 'active' : ''}`}
                data-preview={project.id}
              >
                {project.imageAsset ? (
                  <Image
                    src={project.imageAsset}
                    alt=""
                    width={920}
                    height={680}
                    format="webp"
                    quality={84}
                    loading="lazy"
                    decoding="async"
                    sizes="36vw"
                  />
                ) : (
                  <div class="media-fallback" />
                )}
                <span>{project.title}</span>
              </div>
            ))
          }
        </aside>
      </div>
    </section>

    <section class="portfolio-cta">
      <p class="group-kicker">Un projet en tête ?</p>
      <div>
        <h3>Construisons quelque chose de clair et durable.</h3>
        <button
          type="button"
          class="cta-link popup-trigger"
          data-open-popup="call-popup"
          aria-haspopup="dialog"
        >
          Démarrer une conversation <span aria-hidden="true">→</span>
        </button>
      </div>
    </section>
  </div>
</section>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const portfolio = document.querySelector('#portfolio');
    if (!portfolio) return;

    const chips = [...portfolio.querySelectorAll('[data-filter]')];
    const projectCards = [...portfolio.querySelectorAll('[data-project-card]')];
    const groups = [...portfolio.querySelectorAll('.portfolio-group')];
    const status = portfolio.querySelector('.filter-status');
    const previewLinks = [
      ...portfolio.querySelectorAll('[data-preview-target]'),
    ];
    const previewItems = [...portfolio.querySelectorAll('[data-preview]')];

    const setPreview = (id) => {
      previewItems.forEach((item) => {
        item.classList.toggle('active', item.dataset.preview === id);
      });
    };

    const selectFirstVisiblePreview = () => {
      const firstVisible = previewLinks.find(
        (link) => !link.closest('[data-project-card]')?.hidden,
      );
      if (firstVisible) setPreview(firstVisible.dataset.previewTarget);
    };

    const applyFilter = (filter) => {
      let visibleCount = 0;

      projectCards.forEach((card) => {
        const matches = filter === 'Tous' || card.dataset.category === filter;
        card.hidden = !matches;
        if (matches) visibleCount += 1;
      });

      groups.forEach((group) => {
        group.hidden = ![...group.querySelectorAll('[data-project-card]')].some(
          (card) => !card.hidden,
        );
      });

      if (status) {
        status.textContent = `${visibleCount} projet${visibleCount > 1 ? 's' : ''} affiché${visibleCount > 1 ? 's' : ''}`;
      }

      selectFirstVisiblePreview();
    };

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((button) => {
          const active = button === chip;
          button.classList.toggle('active', active);
          button.setAttribute('aria-pressed', String(active));
        });
        applyFilter(chip.dataset.filter || 'Tous');
      });
    });

    previewLinks.forEach((link) => {
      const activate = () => setPreview(link.dataset.previewTarget);
      link.addEventListener('pointerenter', activate);
      link.addEventListener('focus', activate);
    });
  });
</script>

<style>
  #portfolio {
    --portfolio-bg: var(--color-neutral-950);
    --portfolio-panel: var(--color-neutral-50);
    --portfolio-ink: var(--color-neutral-900);
    --portfolio-muted: var(--color-neutral-500);
    --portfolio-blue: var(--color-brand-500);
    position: fixed;
    inset: 0;
    z-index: 100;
    overflow-y: auto;
    padding: 0 clamp(1rem, 4vw, 4rem) 4rem;
    color: #f8fbff;
    background:
      radial-gradient(
        circle at 82% 4%,
        rgba(29, 165, 254, 0.2),
        transparent 30rem
      ),
      radial-gradient(
        circle at 5% 45%,
        rgba(29, 165, 254, 0.08),
        transparent 26rem
      ),
      var(--portfolio-bg);
    scrollbar-gutter: stable;
  }

  .portfolio-shell {
    width: min(100%, 1320px);
    margin: 0 auto;
  }

  .portfolio-intro {
    padding: clamp(6rem, 12vh, 10rem) 0 clamp(3.5rem, 8vh, 6rem);
  }

  .intro-kicker,
  .group-kicker {
    margin: 0;
    color: var(--portfolio-blue);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(280px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    margin-top: 1.5rem;
  }

  .intro-grid h2 {
    max-width: 11ch;
    margin: 0;
    color: #fff;
    font-size: clamp(3.5rem, 7.4vw, 7.6rem);
    font-weight: 850;
    letter-spacing: -0.07em;
    line-height: 0.86;
  }

  .intro-grid h2 span {
    color: var(--portfolio-blue);
  }

  .intro-copy {
    padding-bottom: 0.35rem;
  }

  .intro-copy p {
    margin: 0;
    color: #bac6d4;
    font-size: clamp(1rem, 1.4vw, 1.2rem);
    line-height: 1.65;
  }

  .intro-link {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    margin-top: 1.5rem;
    color: #fff;
    font-weight: 800;
  }

  .intro-link span {
    color: var(--portfolio-blue);
  }

  .portfolio-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    margin: clamp(3rem, 7vw, 6rem) 0 0;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .portfolio-metrics div {
    display: grid;
    gap: 0.35rem;
    padding: 0 1.5rem;
    border-left: 1px solid rgba(255, 255, 255, 0.12);
  }

  .portfolio-metrics div:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .portfolio-metrics dt {
    color: #fff;
    font-size: clamp(1.7rem, 3vw, 2.7rem);
    font-weight: 850;
    line-height: 1;
  }

  .portfolio-metrics dd {
    margin: 0;
    color: var(--portfolio-muted);
    font-size: 0.82rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .filter-bar {
    position: sticky;
    top: 0;
    z-index: 30;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1.2rem;
    align-items: center;
    margin: 0 calc(clamp(1rem, 4vw, 4rem) * -1) 5rem;
    padding: 1rem clamp(1rem, 4vw, 4rem);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(7, 17, 31, 0.88);
    backdrop-filter: blur(18px);
  }

  .filter-label,
  .filter-status {
    color: var(--portfolio-muted);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .filter-status {
    margin: 0;
    margin-right: 2.5rem;
    white-space: nowrap;
  }

  .filter-chips {
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .chip {
    min-height: 40px;
    padding: 0.55rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    color: #c4cfdb;
    font: inherit;
    font-size: 0.86rem;
    font-weight: 750;
    transition:
      color 0.2s ease,
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.2s ease;
  }

  .chip:hover,
  .chip:focus-visible {
    color: #fff;
    border-color: rgba(29, 165, 254, 0.7);
  }

  .chip.active {
    color: #06101d;
    border-color: var(--portfolio-blue);
    background: var(--portfolio-blue);
  }

  .portfolio-group {
    margin-bottom: clamp(5rem, 10vw, 9rem);
  }

  .group-heading {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .group-heading h3 {
    margin: 0.35rem 0 0;
    color: #fff;
    font-size: clamp(2rem, 4vw, 4rem);
    letter-spacing: -0.045em;
    line-height: 1;
  }

  .group-heading > span {
    color: var(--portfolio-muted);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .featured-list {
    display: grid;
    gap: 2rem;
  }

  .featured-project {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.72fr);
    grid-template-areas: 'visual copy';
    min-height: 520px;
    overflow: hidden;
    border-radius: 18px;
    color: var(--portfolio-ink);
    background: var(--portfolio-panel);
    box-shadow: 0 35px 90px rgba(0, 0, 0, 0.2);
  }

  .featured-project.is-reversed {
    grid-template-columns: minmax(320px, 0.72fr) minmax(0, 1.45fr);
    grid-template-areas: 'copy visual';
  }

  .featured-visual {
    position: relative;
    grid-area: visual;
    min-height: 420px;
    overflow: hidden;
    background: #dfe7ef;
  }

  .featured-visual :global(img),
  .archive-mobile-visual :global(img),
  .archive-preview-item :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-visual :global(img) {
    position: absolute;
    inset: 0;
    transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .visual-number {
    position: absolute;
    left: 1.5rem;
    bottom: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(4rem, 9vw, 9rem);
    font-weight: 900;
    letter-spacing: -0.08em;
    line-height: 0.85;
    text-shadow: 0 12px 30px rgba(0, 0, 0, 0.3);
  }

  .featured-copy {
    grid-area: copy;
    display: flex;
    flex-direction: column;
    padding: clamp(1.75rem, 4vw, 3.4rem);
  }

  .project-overline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    color: #557086;
    font-size: 0.76rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .featured-copy h4 {
    margin: 1.25rem 0 0;
    font-size: clamp(2.2rem, 4vw, 4.5rem);
    letter-spacing: -0.06em;
    line-height: 0.95;
  }

  .project-description {
    margin: 1.2rem 0 0;
    color: #475d70;
    font-size: 1rem;
    line-height: 1.55;
  }

  .project-highlight {
    display: grid;
    gap: 0.3rem;
    margin: 1.7rem 0 0;
    padding-left: 1rem;
    border-left: 3px solid var(--portfolio-blue);
    color: #172b3d;
    font-size: 0.95rem;
    font-weight: 750;
  }

  .project-highlight span {
    color: #698092;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .project-meta {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin: 1.7rem 0 0;
    padding: 1.25rem 0;
    border-top: 1px solid #cfdae3;
    border-bottom: 1px solid #cfdae3;
  }

  .project-meta div {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 0.75rem;
  }

  .project-meta dt {
    color: #758b9c;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-meta dd {
    margin: 0;
    color: #172b3d;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .project-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
    padding-top: 1.6rem;
  }

  .case-link {
    display: inline-flex;
    gap: 0.75rem;
    align-items: center;
    padding: 0.9rem 1.25rem;
    border-radius: 999px;
    color: #fff;
    background: var(--portfolio-ink);
    font-size: 0.88rem;
    font-weight: 800;
  }

  .case-link span,
  .cta-link span {
    color: var(--portfolio-blue);
    transition: transform 0.2s ease;
  }

  .external-links {
    display: flex;
    gap: 0.8rem;
  }

  .external-links a {
    color: #52697b;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .archive-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .archive-list {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
  }

  .archive-item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .archive-link {
    display: grid;
    grid-template-columns:
      3rem minmax(170px, 1fr) minmax(110px, 0.45fr)
      4rem 2rem;
    gap: 1rem;
    align-items: center;
    min-height: 94px;
    color: #dce5ee;
    transition:
      color 0.2s ease,
      padding 0.25s ease,
      background 0.2s ease;
  }

  .archive-number,
  .archive-year,
  .archive-category {
    color: #71859a;
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .archive-name {
    display: grid;
    gap: 0.28rem;
  }

  .archive-name strong {
    font-size: clamp(1.15rem, 2vw, 1.6rem);
    letter-spacing: -0.025em;
  }

  .archive-name small {
    display: -webkit-box;
    overflow: hidden;
    color: #71859a;
    font-size: 0.76rem;
    line-height: 1.3;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
  }

  .archive-arrow {
    color: var(--portfolio-blue);
    font-size: 1.2rem;
    transition: transform 0.2s ease;
  }

  .archive-mobile-visual {
    display: none;
  }

  .archive-preview {
    position: sticky;
    top: 7.5rem;
    height: min(58vh, 520px);
    min-height: 380px;
    overflow: hidden;
    border-radius: 18px;
    background: #111e2d;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.3);
  }

  .archive-preview-item {
    position: absolute;
    inset: 0;
    opacity: 0;
    transform: scale(1.035);
    transition:
      opacity 0.35s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .archive-preview-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(transparent 55%, rgba(0, 0, 0, 0.72));
  }

  .archive-preview-item.active {
    z-index: 1;
    opacity: 1;
    transform: scale(1);
  }

  .archive-preview-item span {
    position: absolute;
    z-index: 2;
    right: 1.5rem;
    bottom: 1.3rem;
