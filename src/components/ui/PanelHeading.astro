---
export interface Props {
  index: string;
  label: string;
  description: string;
}

const { index, label, description } = Astro.props;
---

<header class="panel-heading">
  <p class="panel-kicker">{label} / {index}</p>
  <div class="panel-heading-grid">
    <h2><slot /></h2>
    <p class="panel-description">{description}</p>
  </div>
</header>

<style>
  .panel-heading {
    width: min(100%, var(--container-lg));
    margin-inline: auto;
    padding: clamp(6.5rem, 12vh, 9rem) 0 clamp(3rem, 7vw, 5rem);
    color: var(--color-text-inverse);
  }

  .panel-kicker {
    margin: 0;
    color: var(--color-brand-500);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .panel-heading-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(260px, 0.55fr);
    gap: clamp(2rem, 7vw, 7rem);
    align-items: end;
    margin-top: var(--space-5);
  }

  h2 {
    max-width: 11ch;
    margin: 0;
    color: var(--color-neutral-0);
    font-size: clamp(3.5rem, 7.4vw, 7.6rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 0.86;
  }

  h2 :global(.accent) {
    color: var(--color-brand-500);
  }

  .panel-description {
    margin: 0;
    color: var(--color-neutral-300);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-body);
  }

  @media (max-width: 820px) {
    .panel-heading-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .panel-description {
      max-width: 56ch;
    }
  }

  @media (max-width: 640px) {
    .panel-heading {
      padding-top: 6.5rem;
    }

    h2 {
      font-size: clamp(3.1rem, 15vw, 5rem);
    }
  }
</style>
