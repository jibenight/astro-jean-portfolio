---
import heroVideo from '../assets/video/dev_web.mp4';
import heroPoster from '../assets/images/background-jean-Q100.jpg';
import Button from './ui/Button.astro';
---

<section
  id="home"
  class="hero-video"
  style={`--hero-poster: url(${heroPoster.src})`}
>
  <video
    class="bg-video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={heroPoster.src}
    aria-hidden="true"
  >
    <source src={heroVideo} type="video/mp4" />
  </video>
  <div class="overlay"></div>

  <div class="hero-content">
    <p class="eyebrow">Jean Nguyen — Front-end Astro/Tailwind + IA</p>
    <h1>Des sites Astro rapides, accessibles et maintenables.</h1>
    <p class="lead">
      Intégration front, optimisation Core Web Vitals, automatisation et QA
      assistée par l’IA pour livrer vite, propre et scalable.
    </p>
    <div class="hero-cta">
      <Button size="lg" data-target="portfolio"> Voir mes projets </Button>
      <Button variant="inverse" size="lg" data-target="contact">
        Me contacter
      </Button>
      <div class="kpis">
        <span><strong>Astro/TW</strong> stack cœur</span>
        <span><strong>CWV</strong> focus perfs</span>
        <span><strong>IA</strong> (Claude / ChatGPT / Gemini)</span>
      </div>
    </div>
  </div>
</section>

<style>
  #home {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    color: var(--color-text-inverse);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1.5rem, 4vw, 3rem);
    background: var(--color-neutral-950) var(--hero-poster) center / cover
      no-repeat;
  }

  #home p {
    line-height: 1.4;
  }

  .bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.55);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 20% 20%,
      color-mix(in srgb, var(--color-brand-600) 45%, transparent),
      rgba(0, 0, 0, 0.55)
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    display: grid;
    gap: var(--space-4);
    text-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    font-size: 0.85rem;
    opacity: 0.85;
    margin: 0;
  }

  h1 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin: 0;
  }

  .lead {
    max-width: 560px;
    margin: 0;
  }

  .hero-cta {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .kpis {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0.9;
  }

  .kpis span {
    background: rgba(255, 255, 255, 0.12);
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    #home {
      padding: 1.5rem;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px), (prefers-reduced-data: reduce) {
    .bg-video {
      display: none;
    }
  }
</style>
