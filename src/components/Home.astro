---
import heroVideo from '../assets/video/dev_web.mp4';
import heroPoster from '../assets/images/background-jean-Q100.jpg';
import Button from './ui/Button.astro';
---

<section
  id="home"
  class="hero-video"
  style={`--hero-poster: url(${heroPoster.src})`}
>
  <video
    class="bg-video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={heroPoster.src}
    aria-hidden="true"
  >
    <source src={heroVideo} type="video/mp4" />
  </video>
  <div class="overlay"></div>

  <div class="hero-content">
    <p class="eyebrow">Jean Nguyen — Web, produit & automatisation</p>
    <h1>Développeur augmenté par l’IA, de l’idée au produit.</h1>
    <p class="lead">
      Je combine expertise front-end, automatisation et outils d’IA pour
      concevoir, intégrer, tester et améliorer des expériences web rapides,
      accessibles et maintenables.
    </p>
    <div class="hero-cta">
      <Button size="lg" data-target="portfolio"> Voir mes projets </Button>
      <Button variant="inverse" size="lg" data-target="contact">
        Me contacter
      </Button>
      <div class="kpis">
        <span><strong>Front-end</strong> orienté produit</span>
        <span><strong>IA</strong> intégrée au workflow</span>
        <span><strong>Perfs</strong> & accessibilité</span>
      </div>
    </div>
  </div>
</section>

<style>
  #home {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    color: var(--color-text-inverse);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(2rem, 7vw, 7rem);
    background: var(--color-neutral-950) var(--hero-poster) center / cover
      no-repeat;
  }

  #home p {
    line-height: 1.4;
  }

  .bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.55);
  }

  .overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 20% 20%,
      color-mix(in srgb, var(--color-brand-600) 32%, transparent),
      rgba(7, 17, 31, 0.76)
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    width: min(100%, 820px);
    display: grid;
    gap: var(--space-4);
    text-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.2rem;
    color: var(--color-brand-300);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    opacity: 1;
    margin: 0;
  }

  h1 {
    max-width: 13ch;
    font-size: clamp(3.4rem, 6.2vw, 6.4rem);
    font-weight: 600;
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-tight);
    margin: 0;
  }

  .lead {
    max-width: 60ch;
    margin: 0;
    color: var(--color-neutral-200);
    font-size: var(--font-size-lg);
    line-height: var(--line-height-body);
  }

  .hero-cta {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    flex-wrap: wrap;
  }

  .kpis {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    opacity: 0.9;
  }

  .kpis span {
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(7, 17, 31, 0.35);
    padding: 0.5rem 0.8rem;
    border-radius: var(--radius-pill);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    #home {
      padding: 1.5rem;
      align-items: center;
    }
  }

  @media (max-width: 768px) {
    #home {
      background-position: 20% center;
    }

    .bg-video {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .eyebrow {
      max-width: calc(100% - 4rem);
    }

    h1 {
      font-size: clamp(3rem, 14vw, 4.6rem);
    }

    .hero-content {
      padding-bottom: 4rem;
    }
  }

  @media (prefers-reduced-data: reduce) {
    .bg-video {
      display: none;
    }
  }
</style>
